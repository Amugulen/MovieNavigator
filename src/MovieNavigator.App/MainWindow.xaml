<Window x:Class="MovieNavigator.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding AppTitle}" Height="820" Width="1280"
        Background="#111827">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
    </Window.Resources>
    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="380" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="64" />
            <RowDefinition Height="*" />
            <RowDefinition Height="170" />
        </Grid.RowDefinitions>

        <Grid Grid.ColumnSpan="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="{Binding AppTitle}" Foreground="#F9FAFB" FontSize="28" FontWeight="SemiBold" />
                <TextBlock Text="{Binding StatusMessage}" Foreground="#9CA3AF" FontSize="13" />
            </StackPanel>
            <Button Grid.Column="1" Content="增量扫描全部目录" Click="IncrementalScanAllRootsButton_Click" Padding="18,8" Margin="0,0,8,0" Background="#374151" Foreground="#F9FAFB" FontWeight="SemiBold" />
            <Button Grid.Column="2" Content="选择目录并快速扫描" Click="ScanFolderButton_Click" Padding="18,8" Background="#FBBF24" Foreground="#111827" FontWeight="SemiBold" />
        </Grid>

        <Border Grid.Row="1" Grid.RowSpan="2" Background="#1F2937" CornerRadius="14" Padding="12" Margin="0,0,12,0">
            <StackPanel>
                <TextBlock Text="导航" Foreground="#9CA3AF" Margin="0,0,0,8" />
                <ListBox ItemsSource="{Binding NavigationItems}" SelectedItem="{Binding SelectedSection}" Background="Transparent" Foreground="#F9FAFB" BorderThickness="0" />
                <TextBlock Text="真实分类" Foreground="#9CA3AF" Margin="0,20,0,8" />
                <ListBox ItemsSource="{Binding ClassificationFacets}" SelectedItem="{Binding SelectedClassificationFacet}" DisplayMemberPath="Label" Background="Transparent" Foreground="#F9FAFB" BorderThickness="0" />
            </StackPanel>
        </Border>

        <Grid Grid.Column="1" Grid.Row="1" Margin="0,0,12,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="48" />
                <RowDefinition Height="48" />
                <RowDefinition Height="42" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" FontSize="16" Padding="12" Background="#0F172A" Foreground="#F9FAFB" BorderBrush="#374151" />
            <TextBlock Grid.Row="1" Text="{Binding ResultSummary}" Foreground="#FBBF24" VerticalAlignment="Center" />
            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,8">
                <Button Content="缩略图" Click="ThumbnailGridButton_Click" Padding="14,6" Margin="0,0,8,0" />
                <Button Content="紧凑列表" Click="CompactListButton_Click" Padding="14,6" Margin="0,0,8,0" />
                <Button Content="详情列表" Click="DetailListButton_Click" Padding="14,6" />
            </StackPanel>

            <ListBox Grid.Row="3" ItemsSource="{Binding MediaCards}" SelectedItem="{Binding SelectedMedia}" Background="#111827" BorderThickness="0" Visibility="{Binding IsThumbnailGridView, Converter={StaticResource BoolToVisibility}}">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Width="220" Height="230" Background="#1F2937" CornerRadius="16" Padding="10" Margin="0,0,12,12">
                            <StackPanel>
                                <Border Height="124" Background="#0F172A" CornerRadius="12" Margin="0,0,0,10">
                                    <Grid>
                                        <Image Source="{Binding ThumbnailPath}" Stretch="UniformToFill" />
                                        <TextBlock Text="{Binding Extension}" Foreground="#6B7280" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Grid>
                                </Border>
                                <TextBlock Text="{Binding Title}" Foreground="#F9FAFB" FontSize="15" FontWeight="SemiBold" TextWrapping="Wrap" MaxHeight="42" />
                                <TextBlock Text="{Binding Duration}" Foreground="#D1D5DB" FontSize="12" Margin="0,6,0,0" />
                                <TextBlock Text="{Binding Resolution}" Foreground="#9CA3AF" FontSize="12" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <ListBox Grid.Row="3" ItemsSource="{Binding MediaCards}" SelectedItem="{Binding SelectedMedia}" Background="#111827" BorderThickness="0" Visibility="{Binding IsCompactListView, Converter={StaticResource BoolToVisibility}}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#1F2937" CornerRadius="10" Padding="10" Margin="0,0,0,8">
                            <DockPanel>
                                <TextBlock Text="{Binding Title}" Foreground="#F9FAFB" FontSize="16" FontWeight="SemiBold" DockPanel.Dock="Left" />
                                <TextBlock Text="{Binding Status}" Foreground="#FBBF24" HorizontalAlignment="Right" />
                            </DockPanel>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <ListBox Grid.Row="3" ItemsSource="{Binding MediaCards}" SelectedItem="{Binding SelectedMedia}" Background="#111827" BorderThickness="0" Visibility="{Binding IsDetailListView, Converter={StaticResource BoolToVisibility}}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#1F2937" CornerRadius="12" Padding="12" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="{Binding Title}" Foreground="#F9FAFB" FontSize="18" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding FilePath}" Foreground="#9CA3AF" />
                                <TextBlock Foreground="#D1D5DB">
                                    <Run Text="{Binding Duration}" />
                                    <Run Text=" · " />
                                    <Run Text="{Binding Resolution}" />
                                    <Run Text=" · " />
                                    <Run Text="{Binding Status}" />
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>

        <ScrollViewer Grid.Column="2" Grid.Row="1" Margin="0,0,0,12" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Border Background="#1F2937" CornerRadius="14" Padding="16" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="{Binding DetailTitle}" Foreground="#F9FAFB" FontSize="22" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding SelectedTitle}" Foreground="#FBBF24" FontSize="16" Margin="0,12,0,0" TextWrapping="Wrap" />
                        <TextBlock Text="{Binding SelectedPath, StringFormat=路径：{0}}" Foreground="#D1D5DB" Margin="0,8,0,0" TextWrapping="Wrap" />
                        <TextBlock Text="{Binding SelectedDuration, StringFormat=时长：{0}}" Foreground="#D1D5DB" />
                        <TextBlock Text="{Binding SelectedResolution, StringFormat=分辨率：{0}}" Foreground="#D1D5DB" />
                        <TextBlock Text="导演：待确认" Foreground="#D1D5DB" />
                        <TextBlock Text="国家：苏联" Foreground="#D1D5DB" />
                        <TextBlock Text="{Binding SelectedTags, StringFormat=TAG：{0}}" Foreground="#FBBF24" Margin="0,8,0,16" TextWrapping="Wrap" />
                        <Button Content="{Binding OpenDefaultPlayerText}" Click="OpenDefaultPlayerButton_Click" Margin="0,0,0,8" />
                        <Button Content="{Binding OpenFolderText}" Click="OpenFolderButton_Click" Margin="0,0,0,8" />
                        <Button Content="{Binding MoveOrganizeText}" Click="MoveOrganizeButton_Click" Margin="0,0,0,8" />
                        <Button Content="{Binding RescanText}" Click="RescanButton_Click" Margin="0,0,0,8" />
                        <Button Content="{Binding AddTagText}" Click="AddTagButton_Click" />
                    </StackPanel>
                </Border>
                <Border x:Name="AiSettingsPanel" Background="#1F2937" CornerRadius="14" Padding="16">
                    <StackPanel>
                        <TextBlock Text="AI 文本分类设置" Foreground="#F9FAFB" FontSize="20" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding WarningText}" Foreground="#FBBF24" TextWrapping="Wrap" Margin="0,8,0,12" />
                        <CheckBox Content="启用 AI" IsChecked="{Binding IsEnabled}" Foreground="#F9FAFB" Margin="0,0,0,8" />
                        <TextBlock Text="Provider" Foreground="#9CA3AF" />
                        <TextBox Text="{Binding Provider, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,8" Padding="8" />
                        <TextBlock Text="Base URL" Foreground="#9CA3AF" />
                        <TextBox Text="{Binding BaseUrl, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,8" Padding="8" />
                        <TextBlock Text="Model" Foreground="#9CA3AF" />
                        <TextBox Text="{Binding Model, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,8" Padding="8" />
                        <TextBlock Text="API Key" Foreground="#9CA3AF" />
                        <PasswordBox x:Name="AiApiKeyBox" PasswordChanged="AiApiKeyBox_PasswordChanged" Margin="0,4,0,8" Padding="8" />
                        <TextBlock Text="{Binding StatusMessage}" Foreground="#D1D5DB" TextWrapping="Wrap" Margin="0,0,0,8" />
                        <StackPanel Orientation="Horizontal">
                            <Button Content="保存 AI 设置" Click="SaveAiSettingsButton_Click" Padding="12,6" Margin="0,0,8,0" />
                            <Button Content="Test connection" Click="TestAiConnectionButton_Click" Padding="12,6" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Column="1" Grid.ColumnSpan="2" Grid.Row="2" Background="#1F2937" CornerRadius="14" Padding="16">
            <StackPanel>
                <TextBlock Text="{Binding PendingWorkbenchTitle}" Foreground="#F9FAFB" FontSize="20" FontWeight="SemiBold" />
                <TextBlock Text="填写线索：标题 / 番号 / 导演 / 介绍网址 -> AI文本分类 -> 用户确认后入库" Foreground="#D1D5DB" Margin="0,8,0,8" />
                <Button Content="用AI根据文本线索建议TAG" Click="SuggestTagsWithAiButton_Click" HorizontalAlignment="Left" Padding="12,6" Margin="0,0,0,8" />
                <ListBox ItemsSource="{Binding PendingItems}" DisplayMemberPath="HintText" Height="72" Background="#0F172A" Foreground="#F9FAFB" BorderThickness="0" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
